# =====================================================
# SecondBrain - Variables de entorno
# Copiar a .env y completar
# =====================================================

# -----------------------------------------------------
# PostgreSQL
# -----------------------------------------------------
POSTGRES_USER=secondbrain
POSTGRES_PASSWORD=cambiar_password_seguro_aqui
POSTGRES_DB=secondbrain

# -----------------------------------------------------
# MinIO (object storage)
# -----------------------------------------------------
MINIO_ROOT_USER=secondbrain
MINIO_ROOT_PASSWORD=cambiar_password_seguro_aqui
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_DERIVED=derived

# -----------------------------------------------------
# Qdrant
# -----------------------------------------------------
QDRANT_API_KEY=cambiar_key_seguro_aqui

# -----------------------------------------------------
# Ollama
# -----------------------------------------------------
# LLM principal del tagger. Tras el benchmark (2026-05-11) ganó gemma3:4b:
# multimodal, 128K ctx, ~32 tok/s en la 3080 8GB (entra entero, sin offload pesado),
# JSON estable, sin "thinking" que desperdicie tokens. Alternativas más lentas:
# gemma4:e2b (~28 tok/s, thinking), aya-expanse:8b (~5 tok/s pero buen español).
OLLAMA_MODEL_PRIMARY=qwen3:8b
OLLAMA_MODEL_VISION=qwen3-vl:8b
OLLAMA_MODEL_EMBEDDING=qwen3-embedding:4b

# -----------------------------------------------------
# Whisper
# -----------------------------------------------------
WHISPER_MODEL=large-v3-turbo
WHISPER_LANG=es

# -----------------------------------------------------
# Backend
# -----------------------------------------------------
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info
BACKEND_SECRET_KEY=cambiar_secret_key_aqui_minimo_32_caracteres

# -----------------------------------------------------
# Frontend (Streamlit)
# -----------------------------------------------------
FRONTEND_PORT=8501

# -----------------------------------------------------
# Bridge WhatsApp (whatsapp-web.js) — Sprint 2
# -----------------------------------------------------
BRIDGE_PORT=3001
# Capturar también los mensajes que envío yo (true/false)
BRIDGE_CAPTURE_OUTGOING=true
# Capturar listas de difusión (@broadcast). Los Estados de WhatsApp se filtran siempre.
BRIDGE_INCLUDE_BROADCASTS=false

# -----------------------------------------------------
# Timezone
# -----------------------------------------------------
TZ=America/Argentina/Buenos_Aires
